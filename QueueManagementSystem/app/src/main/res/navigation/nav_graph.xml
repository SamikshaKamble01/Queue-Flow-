<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.queuemanagementsystem.ui.auth.SplashFragment"
        android:label="Splash">
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_user_home"
            app:destination="@id/serviceListFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_admin_home"
            app:destination="@id/adminDashboardFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.queuemanagementsystem.ui.auth.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_login_to_user_home"
            app:destination="@id/serviceListFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_admin_home"
            app:destination="@id/adminDashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.queuemanagementsystem.ui.auth.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_register_to_user_home"
            app:destination="@id/serviceListFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_register_to_admin_home"
            app:destination="@id/adminDashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/serviceListFragment"
        android:name="com.example.queuemanagementsystem.ui.user.ServiceListFragment"
        android:label="Services">
        <action
            android:id="@+id/action_services_to_slots"
            app:destination="@id/slotBookingFragment" />
        <action
            android:id="@+id/action_services_to_token"
            app:destination="@id/myTokenFragment" />
        <action
            android:id="@+id/action_services_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/serviceListFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_services_to_history"
            app:destination="@id/tokenHistoryFragment" />
        <action
            android:id="@+id/action_services_to_profile"
            app:destination="@id/userProfileFragment" />
    </fragment>

    <fragment
        android:id="@+id/slotBookingFragment"
        android:name="com.example.queuemanagementsystem.ui.user.SlotBookingFragment"
        android:label="Slots">
        <action
            android:id="@+id/action_slots_to_token"
            app:destination="@id/myTokenFragment" />
    </fragment>

    <fragment
        android:id="@+id/myTokenFragment"
        android:name="com.example.queuemanagementsystem.ui.user.MyTokenFragment"
        android:label="My Token">
        <action
            android:id="@+id/action_token_to_slots"
            app:destination="@id/slotBookingFragment" />
    </fragment>

    <fragment
        android:id="@+id/tokenHistoryFragment"
        android:name="com.example.queuemanagementsystem.ui.user.TokenHistoryFragment"
        android:label="Token History">
        <action
            android:id="@+id/action_history_to_token"
            app:destination="@id/myTokenFragment" />
    </fragment>

    <fragment
        android:id="@+id/userProfileFragment"
        android:name="com.example.queuemanagementsystem.ui.user.UserProfileFragment"
        android:label="Profile">
        <action
            android:id="@+id/action_profile_to_history"
            app:destination="@id/tokenHistoryFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminDashboardFragment"
        android:name="com.example.queuemanagementsystem.ui.admin.AdminDashboardFragment"
        android:label="Admin Dashboard">
        <action
            android:id="@+id/action_admin_to_queue_control"
            app:destination="@id/queueControlFragment" />
        <action
            android:id="@+id/action_admin_to_slot_management"
            app:destination="@id/slotManagementFragment" />
        <action
            android:id="@+id/action_admin_to_scanner"
            app:destination="@id/qrScannerFragment" />
        <action
            android:id="@+id/action_admin_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/adminDashboardFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_admin_to_reports"
            app:destination="@id/adminReportsFragment" />
    </fragment>

    <fragment
        android:id="@+id/queueControlFragment"
        android:name="com.example.queuemanagementsystem.ui.admin.QueueControlFragment"
        android:label="Queue Control" />

    <fragment
        android:id="@+id/slotManagementFragment"
        android:name="com.example.queuemanagementsystem.ui.admin.SlotManagementFragment"
        android:label="Slot Management" />

    <fragment
        android:id="@+id/qrScannerFragment"
        android:name="com.example.queuemanagementsystem.ui.admin.QrScannerFragment"
        android:label="QR Scanner" />

    <fragment
        android:id="@+id/adminReportsFragment"
        android:name="com.example.queuemanagementsystem.ui.admin.AdminReportsFragment"
        android:label="Reports" />
</navigation>
