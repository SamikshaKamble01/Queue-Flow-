<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Logo Container -->
    <LinearLayout
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:background="@drawable/bg_logo_circle"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Q"
            android:textColor="@color/gold_primary"
            android:textSize="48sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:letterSpacing="0.12"
        android:text="QueueFlow Pro"
        android:textColor="@color/text_primary"
        android:textSize="34sp"
        android:textStyle="bold" />

    <View
        android:layout_width="48dp"
        android:layout_height="3dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_divider_gold" />

    <TextView
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Smart queueing for hospitals, offices, and public service desks"
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:textSize="15sp" />

    <ProgressBar
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="48dp"
        android:indeterminateTint="@color/gold_primary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:letterSpacing="0.18"
        android:text="LOADING…"
        android:textColor="@color/text_hint"
        android:textSize="11sp" />

</LinearLayout>