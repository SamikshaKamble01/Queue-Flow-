<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Page Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:letterSpacing="0.1"
            android:text="YOUR TOKEN"
            android:textColor="@color/gold_primary"
            android:textSize="11sp" />

        <ProgressBar
            android:id="@+id/progress_token"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="end"
            android:indeterminateTint="@color/gold_primary" />

        <!-- Token Hero Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_token_card_hero"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.06"
                        android:text="TOKEN NUMBER"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/text_token_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="A-00"
                        android:textColor="@color/gold_primary"
                        android:textSize="52sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_token_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_chip_green"
                        android:paddingLeft="14dp"
                        android:paddingTop="6dp"
                        android:paddingRight="14dp"
                        android:paddingBottom="6dp"
                        android:text="WAITING"
                        android:textColor="@color/status_success"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- QR Code -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_qr_frame"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/image_qr"
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:contentDescription="Token QR"
                        android:scaleType="fitCenter" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:background="@color/divider_color" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="Show this QR at the counter"
                android:textColor="@color/text_hint"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Stats Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_soft"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.06"
                    android:text="CURRENT TOKEN"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/text_current_token"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="A-00"
                    android:textColor="@color/teal_accent"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_soft"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.06"
                    android:text="PEOPLE AHEAD"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/text_people_ahead"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0"
                    android:textColor="@color/gold_primary"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ETA Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_soft"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.06"
                    android:text="ESTIMATED WAIT"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/text_eta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0 min"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱"
                android:textSize="32sp" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_cancel_token"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_danger_outline"
                android:letterSpacing="0.06"
                android:text="CANCEL TOKEN"
                android:textColor="@color/status_error"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/button_reschedule_token"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_outline"
                android:letterSpacing="0.06"
                android:text="RESCHEDULE"
                android:textColor="@color/gold_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="16dp" />

    </LinearLayout>
</ScrollView>